# ============================================================
# RENAME THIS FILE FROM "env.local" TO ".env.local"
# (just add a dot at the start of the filename)
# ============================================================
#
# Then paste your API keys below:

# X (Twitter) API — get from https://developer.twitter.com
X_BEARER_TOKEN=paste_your_x_bearer_token_here

# Anthropic API — get from https://console.anthropic.com
ANTHROPIC_API_KEY=paste_your_anthropic_api_key_here
